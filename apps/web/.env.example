# URL de base de la passerelle (sans slash final), inlinée au build.
#
# Si vous ouvrez le panel avec http://IP:5173 ou http://nom:5173 (hôte non-local), le front utilise
# automatiquement http(s)://<même hôte>:3000 — pas besoin de variable, et le navigateur n’appelle pas 127.0.0.1.
# Définir VITE_GATEWAY_BASE_URL seulement pour une API sur un autre hôte (URL absolue non-loopback).
#
# Pour tout faire passer par Vite (sans exposer le 3000 sur Internet) : activer le proxy.
# VITE_GATEWAY_DEV_USE_PROXY=1
# VITE_GATEWAY_PROXY_TARGET=http://127.0.0.1:3000
#
# VITE_GATEWAY_BASE_URL=http://127.0.0.1:3000
